
{% if cookiecutter.project_type == "wf-basecalling" %}
env {
    DRD_MODELS_PATH = '<your_dorado_models_path>'
}

docker {
    runOptions = '--user $(id -u):$(id -g) --group-add 100 --volume <your_dorado_models_path>:<your_dorado_models_path>'
}

singularity {
    runOptions = '-B <your_dorado_models_path>'
}
{% endif %}

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
}
